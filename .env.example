# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — set these in the Vercel Dashboard
# (Project -> Settings -> Environment Variables) and in a local .env for dev.
# These are read SERVER-SIDE by api/send-email.js and are NEVER exposed to the
# browser. The private key stays secret.
# ─────────────────────────────────────────────────────────────────────────────
# Get them from https://dashboard.emailjs.com/

# EmailJS service identifier (e.g. service_xxxxxxxx)
EMAILJS_SERVICE_ID=

# EmailJS template identifier (e.g. template_xxxxxxx)
EMAILJS_TEMPLATE_ID=

# EmailJS public key (e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
EMAILJS_PUBLIC_KEY=

# EmailJS private key / secret (e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# This is the ONLY secret and must NEVER be committed or shipped to the client.
EMAILJS_PRIVATE_KEY=
